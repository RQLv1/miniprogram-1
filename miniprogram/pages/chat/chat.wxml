<navigation-bar back="{{false}}" color="black" background="#ffffff">
  <view slot="center" class="nav-center">
    <text class="nav-title">智税工作台</text>
  </view>
</navigation-bar>

<view class="chat-page">
  <view class="quick-actions">
    <view
      wx:for="{{featuredTools}}"
      wx:key="id"
      class="quick-btn"
      data-path="{{item.pagePath}}"
      bindtap="onQuickToolTap"
    >
      {{item.name}}
    </view>
    <view class="quick-btn quick-btn--more" bindtap="onMenuOpen">更多</view>
  </view>

  <view class="chat-actions">
    <view class="chat-action-btn" bindtap="onHistoryTap">
      <image class="chat-action-icon" src="/assets/icons/history.svg" mode="aspectFit" />
      <text class="chat-action-label">历史对话</text>
    </view>
    <view class="chat-action-divider"></view>
    <view class="chat-action-btn" bindtap="onNewChat">
      <image class="chat-action-icon" src="/assets/icons/new-chat.svg" mode="aspectFit" />
      <text class="chat-action-label">新对话</text>
    </view>
  </view>

  <scroll-view class="chat-area" scroll-y scroll-into-view="{{scrollAnchor}}">
    <view wx:if="{{messages.length === 0}}" class="welcome-block">
      <image class="welcome-avatar" src="{{robotAvatar}}" mode="aspectFill" />
      <text class="welcome-name">智税 AI 助手</text>
      <text class="welcome-desc">专业财税问答，精准政策解读</text>

      <view class="info-banner" bindtap="onExpertsTap">
        <view class="info-banner__icon">
          <image class="info-banner__icon-img" src="/assets/icons/expert-consult.svg" mode="aspectFit" />
        </view>
        <text class="info-banner__text">财税专家一对一咨询入口</text>
      </view>

      <view class="section-label">常见问题</view>
      <view
        wx:for="{{faqList}}"
        wx:key="question"
        class="faq-item"
        data-question="{{item.question}}"
        bindtap="onFaqTap"
      >
        <view class="faq-body">
          <text class="faq-text">{{item.question}}</text>
          <text class="faq-tag">{{item.tagsLabel}}</text>
        </view>
        <text class="faq-arrow">›</text>
      </view>
    </view>

    <block wx:for="{{messages}}" wx:key="timestamp">
      <chat-bubble
        role="{{item.role}}"
        content="{{item.content}}"
        loading="{{item.loading}}"
      />
    </block>

    <view id="chat-bottom" class="scroll-anchor"></view>
  </scroll-view>

  <view class="input-bar">
    <input
      class="input-box"
      type="text"
      placeholder="请输入你的财税问题"
      placeholder-class="input-placeholder"
      value="{{inputText}}"
      bindinput="onInputChange"
      bindconfirm="onSend"
      disabled="{{isStreaming}}"
      confirm-type="send"
    />
    <view class="send-btn {{isStreaming ? 'send-btn--disabled' : ''}}" bindtap="onSend">
      发送
    </view>
  </view>
</view>

<view wx:if="{{showMenu}}" class="menu-overlay" style="padding-top: {{overlayTopPadding}}px;">
  <view class="menu-header">
    <text class="menu-title">工具菜单</text>
    <view class="menu-close" bindtap="onMenuClose">×</view>
  </view>
  <scroll-view class="menu-list" scroll-y>
    <view
      wx:for="{{overflowTools}}"
      wx:key="id"
      class="menu-item"
      data-path="{{item.pagePath}}"
      bindtap="onOverflowToolTap"
    >
      <view class="menu-icon" style="background: {{item.accentSoft}};">
        <image class="menu-icon-img" src="{{item.icon}}" mode="aspectFit" style="width:26px;height:26px;" />
      </view>
      <view class="menu-copy">
        <text class="menu-name">{{item.name}}</text>
        <text class="menu-desc">{{item.description}}</text>
      </view>
      <text class="menu-arrow">›</text>
    </view>
    <view class="menu-item" bindtap="onExpertsTap">
      <view class="menu-icon menu-icon--expert">
        <image class="menu-icon-img" src="/assets/icons/expert.svg" mode="aspectFit" style="width:26px;height:26px;" />
      </view>
      <view class="menu-copy">
        <text class="menu-name">财税专家</text>
        <text class="menu-desc">一对一专业咨询</text>
      </view>
      <text class="menu-arrow">›</text>
    </view>
  </scroll-view>
</view>

<view wx:if="{{showHistory}}" class="history-mask" bindtap="onHistoryClose"></view>
<view class="history-drawer {{showHistory ? 'history-drawer--open' : ''}}" style="padding-top: {{overlayTopPadding}}px;">
  <view class="history-header">
    <text class="history-title">历史对话</text>
    <view class="history-head-actions">
      <view class="history-reset" bindtap="onNewChat">新对话</view>
      <view class="history-close" bindtap="onHistoryClose">×</view>
    </view>
  </view>
  <scroll-view class="history-list" scroll-y>
    <view
      wx:for="{{historySessions}}"
      wx:key="_id"
      class="history-item"
      data-idx="{{index}}"
      bindtap="onHistorySelect"
    >
      <text class="history-item__title">{{item.title}}</text>
      <text class="history-item__time">{{item.createdText}}</text>
    </view>
    <view wx:if="{{historySessions.length === 0}}" class="history-empty">
      暂无历史对话
    </view>
  </scroll-view>
</view>
